# Copy to `.env.local` and fill in values. Do not commit `.env.local`.
# Requires: npx vercel link && npx vercel login

# ── Next.js / Supabase (required for the web app) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Vercel Flags (optional locally; use npm run vercel:env after link) ─────────
FLAGS=
FLAGS_SECRET=
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_URL=""
VERCEL_OIDC_TOKEN=""


# ── Supabase CLI — deploy edge functions & db push (scripts in package.json) ─
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxx
SUPABASE_DB_PASSWORD=your-db-password

# ── Web Push (browser subscribe) ──────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── E2E tests (optional) ────────────────────────────────────────────────────
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=

{
  "name": "jobboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "supabase:deploy": "node scripts/deploy-edge-functions.js",
    "supabase:deploy:all": "node scripts/deploy-edge-functions.js",
    "supabase:migrate": "node scripts/push-migrations.js",
    "e2e:smoke": "node e2e/smoke.js",
    "e2e:full": "node e2e/full.js",
    "e2e": "node e2e/smoke.js && node e2e/full.js",
    "vercel:env": "npx --yes vercel@latest env pull .env.vercel.pull.tmp --yes && node scripts/merge-vercel-env.cjs .env.vercel.pull.tmp && rm -f .env.vercel.pull.tmp",
    "codegen:types": "node scripts/codegen-supabase-types.mjs",
    "codegen:zod": "supazod -i src/types/database.ts -o src/types/database.zod.ts -I -s public && node scripts/patch-database-zod-json.mjs",
    "codegen": "npm run codegen:types && npm run codegen:zod",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@flags-sdk/vercel": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@radix-ui/react-slot": "^1.2.4",
    "@reduxjs/toolkit": "^2.12.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-text-align": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@vercel/toolbar": "^0.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "flags": "^4.0.6",
    "framer-motion": "^12.38.0",
    "next": "16.2.1",
    "puppeteer": "^24.40.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.5.0",
    "tiptap-markdown": "^0.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "supabase": "^2.89.1",
    "supazod": "^4.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}

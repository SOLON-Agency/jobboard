#!/bin/sh
#
# Shared pre-commit hook (tracked in git).
#
# Activated automatically by the `prepare` npm script, which runs:
#   git config core.hooksPath .githooks
#
# Steps:
#   0. Regenerate `src/types/database.ts` (when linked / SUPABASE_PROJECT_ID) +
#      `src/types/database.zod.ts` (supazod) — then stage both paths.
#   1. `vercel env pull` → merge into `.env` — sync FLAGS / FLAGS_SECRET (and
#      other Vercel development env vars) without removing locally-only keys.
#      Requires `vercel link` and a logged-in CLI. Use the same flow manually:
#      `npm run vercel:env`.
#   2. `next build` — fail fast on TypeScript / build errors.
#   3. Deploy Supabase Edge Functions that changed under `supabase/functions/`.
#      If `_shared/` changed, redeploy everything.
#   4. Push Supabase migrations when any `supabase/migrations/*.sql` is staged.
#
# Opt-outs (set to 1 to skip individual steps):
#   SKIP_CODEGEN=1          bypass Supabase types + database.zod.ts regeneration
#   SKIP_VERCEL_ENV_PULL=1  bypass Vercel `env pull`
#   SKIP_BUILD=1            bypass the Next.js build
#   SKIP_DEPLOY=1           bypass edge-function deployment
#   SKIP_MIGRATIONS=1       bypass `supabase db push`
#
# Bypass everything for a WIP commit:
#   git commit --no-verify -m "wip"
#
# Offline / no Vercel CLI login: use SKIP_VERCEL_ENV_PULL=1 (pull step warns and continues).
# Offline types pull: codegen:types skips when not linked; supazod still refreshes Zod from committed types.

set -e

# shellcheck disable=SC1091
. "$(dirname "$0")/ensure-npm.sh"
ensure_npm_in_path

FUNCTIONS_DIR="supabase/functions"
MIGRATIONS_DIR="supabase/migrations"
DEPLOY_SCRIPT="scripts/deploy-edge-functions.js"
MIGRATE_SCRIPT="scripts/push-migrations.js"

# ── 0. Supabase TypeScript types + Zod (supazod) ─────────────────────────────

if [ "${SKIP_CODEGEN:-0}" = "1" ]; then
  echo "⚠️  SKIP_CODEGEN=1 — skipping DB types + database.zod.ts codegen."
else
  echo ""
  echo "📦  Regenerating DB types + database.zod.ts..."
  echo ""
  npm run codegen
  git add src/types/database.ts src/types/database.zod.ts
fi

# ── 1. Vercel env pull → .env (merge) ────────────────────────────────────────

if [ "${SKIP_VERCEL_ENV_PULL:-0}" = "1" ]; then
  echo "⚠️  SKIP_VERCEL_ENV_PULL=1 — skipping Vercel env pull."
else
  if [ ! -f .vercel/project.json ]; then
    echo "ℹ️  No .vercel/project.json — skipping Vercel env pull (run: npx vercel link)."
  else
    echo ""
    echo "🚩  Pulling Vercel development env → merging into .env ..."
    echo ""
    tmp_env=".env.vercel.pull.tmp"
    rm -f "$tmp_env"
    if npx --yes vercel@latest env pull "$tmp_env" --yes; then
      node scripts/merge-vercel-env.cjs "$tmp_env"
      rm -f "$tmp_env"
      echo ""
      echo "✅ Vercel env merged into .env."
      echo ""
    else
      rm -f "$tmp_env"
      echo ""
      echo "⚠️  vercel env pull failed (not logged in, or network). Continuing commit."
      echo "   Fix: npx vercel login   or   SKIP_VERCEL_ENV_PULL=1 git commit ..."
      echo ""
    fi
  fi
fi

# ── 2. Next.js build check ──────────────────────────────────────────────────

if [ "${SKIP_BUILD:-0}" = "1" ]; then
  echo "⚠️  SKIP_BUILD=1 — skipping build check."
else
  echo ""
  echo "🏗️  Running Next.js build check..."
  echo ""

  if npm run build; then
    echo ""
    echo "✅ Build passed — proceeding with commit."
    echo ""
  else
    echo ""
    echo "❌ Build failed. Fix the errors above before committing."
    echo "   (To bypass this check run: SKIP_BUILD=1 git commit ...)"
    echo ""
    exit 1
  fi
fi

# ── 3. Supabase Edge Functions deployment ───────────────────────────────────

if [ "${SKIP_DEPLOY:-0}" = "1" ]; then
  echo "⚠️  SKIP_DEPLOY=1 — skipping edge-function deployment."
else
  staged_fns=$(git diff --cached --name-only --diff-filter=ACMR | grep "^${FUNCTIONS_DIR}/" || true)

  if [ -n "$staged_fns" ]; then
    echo ""
    echo "🔧 Supabase Edge Functions changed — deploying before commit..."
    echo ""

    shared_changed=$(echo "$staged_fns" | grep "^${FUNCTIONS_DIR}/_shared/" || true)

    if [ -n "$shared_changed" ]; then
      echo "   _shared/ modified — deploying all functions."
      node "$DEPLOY_SCRIPT"
    else
      changed_slugs=$(echo "$staged_fns" \
        | grep -v "^${FUNCTIONS_DIR}/_" \
        | sed "s|${FUNCTIONS_DIR}/\([^/]*\)/.*|\1|" \
        | sort -u \
        | tr '\n' ' ')

      if [ -n "$changed_slugs" ]; then
        # shellcheck disable=SC2086
        node "$DEPLOY_SCRIPT" $changed_slugs
      fi
    fi
  fi
fi

# ── 4. Supabase migrations push ─────────────────────────────────────────────

if [ "${SKIP_MIGRATIONS:-0}" = "1" ]; then
  echo "⚠️  SKIP_MIGRATIONS=1 — skipping migration push."
else
  staged_migrations=$(git diff --cached --name-only --diff-filter=ACMR | grep "^${MIGRATIONS_DIR}/.*\.sql$" || true)

  if [ -n "$staged_migrations" ]; then
    echo ""
    echo "🗄️  Supabase migrations changed — pushing to the linked project..."
    echo ""
    node "$MIGRATE_SCRIPT"
  fi
fi

exit 0
